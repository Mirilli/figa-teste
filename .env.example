# ─────────────────────────────────────────────
# GRANOVITA – Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no repositório!
# ─────────────────────────────────────────────

# Servidor
NODE_ENV=development
PORT=3000
BASE_URL=https://seudominio.com.br

# Banco de dados (SQLite – apenas o caminho do arquivo)
DB_PATH=./data/granovita.db

# JWT – Gere segredos aleatórios com: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_ACCESS_SECRET=SUBSTITUA_POR_STRING_ALEATORIA_64_CHARS
JWT_REFRESH_SECRET=SUBSTITUA_POR_OUTRA_STRING_ALEATORIA_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Sessão / CSRF
SESSION_SECRET=SUBSTITUA_POR_STRING_ALEATORIA_PARA_SESSAO

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000
MP_PUBLIC_KEY=APP_USR-00000000-0000-0000-0000-000000000000
MP_WEBHOOK_SECRET=SUBSTITUA_PELO_WEBHOOK_SECRET_DO_MP

# Admin – primeiro acesso (será criado automaticamente na inicialização)
ADMIN_EMAIL=admin@granovita.com.br
ADMIN_PASSWORD=TrucaForteSenha@2025!

# Frete (valores em R$, 0 = grátis)
FREE_SHIPPING_THRESHOLD=100
SHIPPING_COST=15.90

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
