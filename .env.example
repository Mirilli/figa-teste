# ──────────────────────────────────────────────────────────────────────
# GRANOVITA – Variáveis de Ambiente (.env.example)
# Copie para .env e preencha os valores. NUNCA commite o .env!
# ──────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Banco de dados (PostgreSQL)
# Local: instale o PostgreSQL e execute: createdb granovita
DATABASE_URL=postgresql://usuario:senha@localhost:5432/granovita

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=SUBSTITUA_64_CHARS_ALEATORIOS
JWT_REFRESH_SECRET=SUBSTITUA_OUTROS_64_CHARS_ALEATORIOS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Mercado Pago — https://www.mercadopago.com.br/developers/panel
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000
MP_WEBHOOK_SECRET=SUBSTITUA_PELO_WEBHOOK_SECRET_DO_MP

# Admin inicial (criado automaticamente na primeira execução)
ADMIN_EMAIL=admin@granovita.com.br
ADMIN_PASSWORD=TrocaPorSenhaForte@2025!

# Frete
FREE_SHIPPING_THRESHOLD=100
SHIPPING_COST=15.90

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
